# Optional: set a key here ONLY if the OS keyring is unavailable and you
# want the encrypted-file fallback to skip first-run prompting.
# In normal use, keys are stored via the UI into the OS keyring (spec §7.7.2)
# and this file is NOT needed.
#
# ANTHROPIC_API_KEY=sk-ant-...
# VOYAGE_API_KEY=pa-...

# For tests only — gates live-API tests (spec §7.7.8).
# TEST_ANTHROPIC_KEY=sk-ant-...
