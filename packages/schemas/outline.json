{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://lawschool.local/schemas/outline.json",
  "title": "HierarchicalOutline",
  "description": "Spec §5.11. TOC-structured course outline, each topic with rules, controlling cases, policy rationales, exam traps, cross-refs.",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "course",
    "topics",
    "sources"
  ],
  "properties": {
    "course": {
      "type": "string"
    },
    "topics": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/TopicNode"
      }
    },
    "sources": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  },
  "$defs": {
    "TopicNode": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "title",
        "level"
      ],
      "properties": {
        "title": {
          "type": "string"
        },
        "level": {
          "type": "integer",
          "minimum": 1,
          "maximum": 6
        },
        "toc_source_page": {
          "type": [
            "integer",
            "null"
          ]
        },
        "rule_statements": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "controlling_cases": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": true,
            "required": [
              "case_name"
            ],
            "properties": {
              "case_name": {
                "type": "string"
              },
              "cite": {
                "type": [
                  "string",
                  "null"
                ]
              },
              "one_line": {
                "type": [
                  "string",
                  "null"
                ]
              }
            }
          }
        },
        "policy_rationales": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "exam_traps": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "cross_references": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Breadcrumbs into other topics — e.g., 'see also Covenants § running with the land'."
        },
        "children": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/TopicNode"
          }
        }
      }
    }
  }
}
